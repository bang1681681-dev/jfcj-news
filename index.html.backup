    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #0088cc;
            --primary-dark: #006699;
            --bg-dark: #0f1419;
            --bg-card: #1a1f2e;
            --text-primary: #ffffff;
            --text-secondary: #8899a6;
            --accent: #ffd700;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            background: var(--bg-dark);
            color: var(--text-primary);
            min-height: 100vh;
            padding: 20px;
            background-image: 
                radial-gradient(ellipse at top, #1a2a3a 0%, transparent 50%),
                radial-gradient(ellipse at bottom, #0a1520 0%, transparent 50%);
        }

        .container {
            max-width: 700px;
            width: 100%;
            margin: 0 auto;
        }

        .logo {
            font-size: 60px;
            margin-bottom: 16px;
            animation: float 3s ease-in-out infinite;
            text-align: center;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        h1 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 16px;
            text-align: center;
            background: linear-gradient(135deg, #ffd700, #ff8c00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .description {
            color: var(--text-secondary);
            font-size: 1rem;
            line-height: 1.8;
            margin-bottom: 24px;
            padding: 16px;
            background: var(--bg-card);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center;
        }

        .description span {
            display: block;
            margin-bottom: 6px;
        }

        .description span:last-child {
            margin-bottom: 0;
        }

        .telegram-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: linear-gradient(135deg, #0088cc, #00aaff);
            color: white;
            text-decoration: none;
            padding: 14px 32px;
            border-radius: 50px;
            font-size: 1rem;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(0, 136, 204, 0.4);
            margin-bottom: 30px;
        }

        .telegram-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(0, 136, 204, 0.6);
        }

        .telegram-btn svg {
            width: 24px;
            height: 24px;
        }

        .section-title {
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 20px;
            color: var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .news-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .news-card {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 18px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .news-card:hover {
            border-color: var(--primary);
            transform: translateY(-2px);
        }

        .news-time {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-bottom: 10px;
        }

        .news-content {
            font-size: 0.95rem;
            line-height: 1.7;
            white-space: pre-wrap;
            word-wrap: break-word;
        }

        .news-content a {
            color: var(--primary);
            text-decoration: none;
        }

        .news-content a:hover {
            text-decoration: underline;
        }

        .stats {
            margin-top: 40px;
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--accent);
        }

        .stat-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            margin-top: 4px;
        }

        footer {
            margin-top: 50px;
            text-align: center;
            color: var(--text-secondary);
            font-size: 0.8rem;
            padding-bottom: 20px;
        }

        @media (max-width: 480px) {
            h1 {
                font-size: 1.6rem;
            }

            .logo {
                font-size: 50px;
            }

            .news-card {
                padding: 14px;
            }
        }
    </style>
</head>
